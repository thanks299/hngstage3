{
  "name": "insighta-labs-api",
  "version": "2.0.0",
  "description": "Insighta Labs+ API with Authentication, RBAC, and Advanced Features",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:verbose": "jest --verbose --runInBand --forceExit",
    "migrate": "node scripts/migrate.js",
    "ci": "npm install && npm run migrate && npm test",
    "db:setup": "npm run migrate && npm run seed",
    "build": "echo 'No build step required'",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf": "^3.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "fast-csv": "^5.0.5",
    "helmet": "^7.2.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
