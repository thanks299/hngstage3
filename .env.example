# Server
PORT=3000
NODE_ENV=production

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=insighta_user
DB_PASSWORD=your_password
DB_NAME=insighta_labs

# JWT Tokens
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ACCESS_EXPIRY=180  # 3 minutes in seconds
JWT_REFRESH_EXPIRY=300  # 5 minutes in seconds

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Frontend URLs
WEB_PORTAL_URL=http://localhost:3001
CLI_CALLBACK_URL=http://localhost:8080/callback

# API Rate Limits
AUTH_RATE_LIMIT=10
API_RATE_LIMIT=60